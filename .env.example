# Copy to `.env` and fill in values from https://www.emailjs.com/
# Frontend-only contact form — no backend required.

# EmailJS → Account → API Keys
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# EmailJS → Email Services → your service ID
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx

# EmailJS → Email Templates → your template ID
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Your inbox (shown in the email template)
VITE_MY_EMAIL=abhishek.choudhary7631@gmail.com
